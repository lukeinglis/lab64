#!/usr/bin/env bash
set -euo pipefail

LAB64_VERSION="lab64 v0.1.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared logging library
. "$SCRIPT_DIR/lib/logging.sh"

QUIET=0
VERBOSE=0
PASSTHROUGH_FLAGS=()

usage() {
    cat <<EOF
lab64 - Unified CLI for the Lab 64 toolchain

Usage: lab64 [options] <command> [args...]

Commands:
  render     Render character sprites from Blender models
  pack       Pack sprites into a .o2r mod archive
  validate   Validate a .o2r mod archive
  sync       Transfer .o2r files to a Windows machine
  check      Run the feasibility checklist
  version    Show version of all components
  doctor     Check that all dependencies are available

Options:
  --help      Show this help message
  --version   Show lab64 version string
  --verbose   Enable verbose output (passed to subcommands)
  --quiet     Suppress non-error output (passed to subcommands)

Examples:
  lab64 render --character dalmatian --blend-file assets/characters/dalmatian/dalmatian.blend
  lab64 pack dalmatian assets/characters/dalmatian/sprites
  lab64 validate mods/animal-pack/dalmatian.o2r
  lab64 doctor
EOF
    exit 2
}

cmd_version() {
    echo "$LAB64_VERSION"
    echo ""
    printf "python3:     "
    python3 --version 2>/dev/null || echo "not found"
    printf "blender:     "
    blender --version 2>/dev/null | head -1 || echo "not found"
    printf "shellcheck:  "
    shellcheck --version 2>/dev/null | grep '^version:' || echo "not found"
    printf "zip:         "
    zip --version 2>/dev/null | head -2 | tail -1 || echo "not found"
    printf "unzip:       "
    unzip -v 2>/dev/null | head -1 || echo "not found"
}

cmd_doctor() {
    echo "Lab 64 dependency check"
    echo "======================"
    echo ""

    local pass=0
    local fail=0

    check_dep() {
        local name="$1"
        local cmd="$2"
        printf "  %-14s" "$name:"
        if command -v "$cmd" >/dev/null 2>&1; then
            echo "OK"
            pass=$((pass + 1))
        else
            echo "MISSING"
            fail=$((fail + 1))
        fi
    }

    check_dep "python3" "python3"
    check_dep "blender" "blender"
    check_dep "zip" "zip"
    check_dep "unzip" "unzip"
    check_dep "shellcheck" "shellcheck"
    check_dep "bats" "bats"
    check_dep "pytest" "pytest"

    echo ""
    echo "  Pass: $pass  Fail: $fail"

    if [ "$fail" -gt 0 ]; then
        echo ""
        echo "Some dependencies are missing. See docs/setup.md for installation instructions."
        return 1
    fi

    echo ""
    echo "All dependencies available."
    return 0
}

cmd_render() {
    exec "$SCRIPT_DIR/render-character-sprites.py" ${PASSTHROUGH_FLAGS[@]+"${PASSTHROUGH_FLAGS[@]}"} "$@"
}

cmd_pack() {
    exec "$SCRIPT_DIR/pack-character-mod.sh" ${PASSTHROUGH_FLAGS[@]+"${PASSTHROUGH_FLAGS[@]}"} "$@"
}

cmd_validate() {
    exec "$SCRIPT_DIR/validate-mod.sh" ${PASSTHROUGH_FLAGS[@]+"${PASSTHROUGH_FLAGS[@]}"} "$@"
}

cmd_sync() {
    exec "$SCRIPT_DIR/sync-to-windows.sh" ${PASSTHROUGH_FLAGS[@]+"${PASSTHROUGH_FLAGS[@]}"} "$@"
}

cmd_check() {
    exec "$SCRIPT_DIR/check-feasibility.sh" ${PASSTHROUGH_FLAGS[@]+"${PASSTHROUGH_FLAGS[@]}"} "$@"
}

# Parse global options before the subcommand
while [ $# -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            ;;
        --version)
            echo "$LAB64_VERSION"
            exit 0
            ;;
        --verbose)
            VERBOSE=1
            PASSTHROUGH_FLAGS+=("--verbose")
            shift
            ;;
        --quiet)
            QUIET=1
            PASSTHROUGH_FLAGS+=("--quiet")
            shift
            ;;
        -*)
            log_error "Unknown option: $1"
            usage
            ;;
        *)
            break
            ;;
    esac
done

logging_init

if [ $# -eq 0 ]; then
    log_error "No command specified"
    usage
fi

COMMAND="$1"
shift

case "$COMMAND" in
    render)   cmd_render "$@" ;;
    pack)     cmd_pack "$@" ;;
    validate) cmd_validate "$@" ;;
    sync)     cmd_sync "$@" ;;
    check)    cmd_check "$@" ;;
    version)  cmd_version ;;
    doctor)   cmd_doctor ;;
    *)
        log_error "Unknown command: $COMMAND"
        usage
        ;;
esac
